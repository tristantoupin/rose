*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.pytest_cache/
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.cache/

# Virtual environments
.venv/
venv/
ENV/
env/
.env/
.python-version

# -----------------------------------------------------------------------------
# Package managers
# -----------------------------------------------------------------------------
# pip
pip-log.txt
pip-delete-this-directory.txt

# uv
.uv/
uv.lock

# Poetry
poetry.lock

# Pipenv
Pipfile.lock

# PDM
.pdm-python
.pdm.toml
.pdm-build/

# Hatch
.hatch/

# -----------------------------------------------------------------------------
# Secrets & credentials
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets/
credentials/
credentials.json
service-account*.json
*.token
.auth
.netrc

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
# VS Code / Cursor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
!.vscode/launch.json.example
!.vscode/tasks.json.example
*.code-workspace

# Cursor local/session state (keep rules & skills)
.cursor/chat/
.cursor/plans/
.cursor/projects/
.cursor/mcp.json
.cursor/environment.json
.cursor/.agent-tools/

# JetBrains
.idea/
*.iml
*.iws
*.ipr
out/

# Vim
*.swp
*.swo
*~
.netrwhist
Session.vim

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# Sublime Text
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# Logs & temp files
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej

# -----------------------------------------------------------------------------
# Documentation builds
# -----------------------------------------------------------------------------
site/
docs/_build/
docs/.doctrees/
.docusaurus/
.next/
out/

# -----------------------------------------------------------------------------
# Testing & profiling
# -----------------------------------------------------------------------------
.benchmarks/
prof/
*.prof
*.lprof

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Docker (if used later)
# -----------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# -----------------------------------------------------------------------------
# Terraform / IaC (if used later)
# -----------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
override.tf
override.tf.json

# -----------------------------------------------------------------------------
# Node (if frontend/tooling added later)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
.yarn/
package-lock.json
yarn.lock
pnpm-lock.yaml
.turbo/
.parcel-cache/
.nuxt/
.vercel/

# -----------------------------------------------------------------------------
# Rose CLI runtime (user-local, not project)
# -----------------------------------------------------------------------------
# Config and caches live in ~/.rose — never in this repo
.rose/

# Local workspace sandboxes created during dev
workspaces/
sandbox/
scratch/

